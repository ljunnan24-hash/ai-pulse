# MySQL (RDS)
DATABASE_URL=mysql+pymysql://USER:PASSWORD@rm-xxxx.mysql.rds.aliyuncs.com:3306/aipulse?charset=utf8mb4

# Public URL of this API (used in confirmation links in emails)
PUBLIC_APP_URL=https://api.yourdomain.com

# English marketing site (redirects after confirm / unsubscribe / manage)
FRONTEND_URL=https://www.yourdomain.com

# Volcengine Ark — model endpoint ID from console
DOUBAO_API_KEY=
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-xxxx

# Aliyun DirectMail SMTP
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=AI Pulse <noreply@yourdomain.com>

# Optional: comma-separated RSS URLs (otherwise built-in defaults are used)
# RSS_FEED_URLS=
